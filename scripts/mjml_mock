#!/bin/bash
# Proxy script to handle MJML compilation while preserving the expected version echo for boot checks

# Try to find node in common locations if not in PATH
NODE_BIN=$(command -v node)
if [ -z "$NODE_BIN" ]; then
  # Try typical NVM path based on user environment
  if [ -f "/Users/Quaint/.nvm/versions/node/v18.20.6/bin/node" ]; then
    NODE_BIN="/Users/Quaint/.nvm/versions/node/v18.20.6/bin/node"
  fi
fi

if [[ "$*" == *"--version"* ]]; then
  echo 4.18.0
else
  # Use found node binary to run the actual mjml binary
  "$NODE_BIN" "$(dirname "$0")/../node_modules/mjml/bin/mjml" "$@"
fi
