<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @seller.enterprise_name %> - Product Catalog</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #fbbf24; /* Amber 400 */
            --primary-dark: #d97706; /* Amber 600 */
            --dark: #111827; /* Gray 900 */
            --secondary: #6b7280; /* Gray 500 */
            --accent: #fffbeb; /* Amber 50 */
            --white: #ffffff;
            --border: #e5e7eb;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fafafa;
            color: var(--dark);
            line-height: 1.45;
            padding: 16px;
            position: relative;
        }


        .container {
            max-width: 1100px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.98);
            padding: 18px;
            border-radius: 10px;
            border-top: 4px solid var(--primary);
            border: 1px solid var(--border);
        }

        header {
            margin-bottom: 16px;
            padding-bottom: 14px;
            border-bottom: 1px solid var(--border);
            position: relative;
        }

        .logos-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 10px;
            width: 100%;
        }

        .brand-lockup {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
            flex: 1;
        }

        .brand-logo-wrap,
        .cc-logo-wrap {
            height: 42px;
            min-width: 42px;
            padding: 6px 8px;
            border: 1px solid var(--border);
            border-radius: 10px;
            background: var(--white);
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .header-logo {
            height: 44px;
            max-width: 140px;
            object-fit: contain;
        }

        .cc-logo {
            height: 38px;
            object-fit: contain;
        }

        .header-copy {
            min-width: 0;
            text-align: left;
            flex: 1;
        }

        .catalog-chip {
            display: inline-flex;
            align-items: center;
            padding: 3px 8px;
            border-radius: 999px;
            background: var(--accent);
            color: var(--primary-dark);
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        header h1 {
            color: var(--dark);
            font-size: 20px;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            font-weight: 800;
            line-height: 1.15;
        }

        header .subtitle {
            color: var(--secondary);
            font-size: 11px;
            font-weight: 600;
            margin-top: 4px;
        }

        .header-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding-top: 10px;
            border-top: 1px solid var(--border);
            flex-wrap: wrap;
        }

        .meta-cluster {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        header .meta {
            font-size: 10px;
            color: var(--secondary);
            background: #f9fafb;
            display: inline-flex;
            align-items: center;
            padding: 4px 8px;
            border-radius: 999px;
            font-weight: 600;
            border: 1px solid var(--border);
        }

        .meta-emphasis {
            color: var(--dark);
            font-weight: 700;
        }

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-top: 12px;
        }

        th {
            background-color: var(--dark);
            color: var(--white);
            text-align: left;
            padding: 10px 10px;
            font-weight: 600;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
        }

        th:first-child { border-top-left-radius: 8px; }
        th:last-child { border-top-right-radius: 8px; }

        td {
            padding: 10px;
            border-bottom: 1px solid var(--border);
            vertical-align: top;
            font-size: 12px;
        }

        tr:nth-child(even) {
            background-color: #f9fafb;
        }

        tr:hover {
            background-color: var(--accent);
        }

        .img-cell {
            width: 72px;
        }

        .product-img {
            width: 56px;
            height: 56px;
            object-fit: contain;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: #fff;
        }

        .price {
            font-weight: 800;
            color: var(--primary-dark);
            white-space: nowrap;
            font-size: 12px;
        }

        .deleted-badge {
            display: inline-block;
            padding: 2px 8px;
            background-color: #ef4444;
            color: white;
            border-radius: 9999px;
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
            margin-left: 8px;
            vertical-align: middle;
            border: 1px solid rgba(0,0,0,0.1);
        }

        .desc {
            max-width: 440px;
            color: var(--secondary);
            font-size: 11px;
            margin-top: 4px;
            line-height: 1.4;
        }

        .desc > *:first-child {
            margin-top: 0;
        }

        .desc > *:last-child {
            margin-bottom: 0;
        }

        .desc p,
        .desc ul,
        .desc ol,
        .desc blockquote,
        .desc pre,
        .desc h1,
        .desc h2,
        .desc h3,
        .desc h4,
        .desc h5,
        .desc h6 {
            margin: 0 0 6px;
        }

        .desc ul,
        .desc ol {
            padding-left: 16px;
        }

        .desc h1,
        .desc h2,
        .desc h3,
        .desc h4,
        .desc h5,
        .desc h6 {
            color: var(--dark);
            font-size: 12px;
            font-weight: 700;
        }

        .desc code,
        .desc pre {
            font-size: 10px;
            background: #f3f4f6;
            border-radius: 4px;
        }

        .desc code {
            padding: 1px 4px;
        }

        .desc pre {
            padding: 6px;
            overflow-x: auto;
        }

        .desc a {
            color: var(--primary-dark);
            text-decoration: none;
        }

        .view-link {
            display: inline-flex;
            align-items: center;
            margin-top: 8px;
            padding: 4px 10px;
            background-color: var(--dark);
            color: var(--white);
            text-decoration: none;
            border-radius: 6px;
            font-size: 10px;
            font-weight: 600;
            transition: all 0.2s;
        }

        .view-link:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
        }

        .num-cell {
            width: 40px;
            color: var(--secondary);
            font-weight: 600;
            font-size: 11px;
        }

        .no-print-actions {
            position: fixed;
            bottom: 16px;
            right: 16px;
            display: flex;
            gap: 10px;
            z-index: 1000;
        }

        .action-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            background: var(--dark);
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 700;
            font-size: 11px;
            transition: all 0.3s;
            text-decoration: none;
        }

        .action-btn:hover {
            transform: translateY(-1px);
            background: var(--primary-dark);
            color: white;
        }

        .action-btn.csv {
            background: #10b981; /* Green 500 */
        }

        .action-btn.csv:hover {
            background: #059669; /* Green 600 */
        }

        @media print {
            body { 
                background: white !important; 
                padding: 0 !important; 
                margin: 0 !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
            body::before {
                content: "";
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: -100;
                background-image: url('https://carboncube-ke.com/logo.png') !important;
                background-repeat: repeat-y !important;
                background-position: center !important;
                background-size: 600px !important;
                opacity: 0.04 !important;
                pointer-events: none;
                display: block !important;
            }
            .container { 
                box-shadow: none !important; 
                width: 100% !important; 
                max-width: 100% !important; 
                padding: 0 !important; 
                border-top: none !important;
                border: none !important;
                background: white !important;
            }
            .no-print-actions { display: none !important; }
            .view-link { display: none !important; }
            .desc { display: none !important; }
            
            table { 
                width: 100% !important; 
                page-break-inside: auto; 
                border-collapse: collapse !important;
            }
            tr { 
                page-break-inside: avoid !important; 
                page-break-after: auto !important; 
            }
            th { 
                background-color: #f3f4f6 !important; 
                color: black !important; 
                border-bottom: 2px solid #000 !important;
                position: static !important;
            }
            td {
                border-bottom: 1px solid #eee !important;
            }
            .product-img {
                border: 1px solid #eee !important;
            }
            .meta {
                background: #f9fafb !important;
                border: 1px solid #eee !important;
            }
            @page { 
                margin: 1.5cm; 
                size: portrait;
            }
        }

        .footer {
            margin-top: 12px;
            padding-top: 10px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            gap: 12px;
            color: var(--secondary);
            font-size: 10px;
        }

        @media (max-width: 768px) {
            body {
                padding: 10px;
            }

            .container {
                padding: 12px;
            }

            .logos-row {
                align-items: flex-start;
                flex-direction: column;
            }

            .header-meta {
                flex-direction: column;
                align-items: flex-start;
            }

            table {
                display: block;
                overflow-x: auto;
                white-space: nowrap;
            }

            .footer {
                flex-direction: column;
            }
        }
    </style>
    <!-- FontAwesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Floating Action Buttons -->
    <div class="no-print-actions">
        <a href="javascript:window.print()" class="action-btn">
            <i class="fas fa-file-pdf"></i> Save as PDF
        </a>
        <a href="<%= request.original_url %>&format=csv" class="action-btn csv">
            <i class="fas fa-file-csv"></i> Download CSV
        </a>
    </div>
    <div class="container">
        <header>
            <div class="logos-row">
                <div class="brand-lockup">
                    <% if @seller.profile_picture.present? %>
                        <div class="brand-logo-wrap">
                            <img src="<%= @seller.profile_picture %>" alt="<%= @seller.enterprise_name %> Logo" class="header-logo">
                        </div>
                    <% end %>
                    <div class="header-copy">
                        <div class="catalog-chip">Seller Catalog</div>
                        <h1><%= @seller.enterprise_name.upcase %></h1>
                        <p class="subtitle">Official product catalog and inventory list</p>
                    </div>
                </div>
                <div class="cc-logo-wrap">
                    <img src="https://carboncube-ke.com/logo.png" alt="Carbon Cube Logo" class="cc-logo">
                </div>
            </div>
            <div class="header-meta">
                <div class="meta-cluster">
                    <span class="meta">Generated on <span class="meta-emphasis">&nbsp;<%= Time.current.strftime('%B %d, %Y') %></span></span>
                    <span class="meta">Inventory <span class="meta-emphasis">&nbsp;<%= @products.size %> items</span></span>
                </div>
                <span class="meta">Powered by <span class="meta-emphasis">&nbsp;Carbon Cube</span></span>
            </div>
        </header>

        <table>
            <thead>
                <tr>
                    <th class="num-cell">#</th>
                    <th class="img-cell">Image</th>
                    <th>Product Details</th>
                    <th>Category</th>
                    <th>Price (KES)</th>
                </tr>
            </thead>
            <tbody>
                <% @products.each_with_index do |p, index| %>
                <tr>
                    <td class="num-cell"><%= index + 1 %></td>
                    <td class="img-cell">
                        <% if p.media_urls.present? %>
                            <img src="<%= p.media_urls.first %>" class="product-img" loading="lazy">
                        <% else %>
                            <div class="product-img" style="display:flex;align-items:center;justify-content:center;color:#ccc;background:#eee;font-size:10px;">No Image</div>
                        <% end %>
                    </td>
                    <td>
                        <div style="font-weight: 700; font-size: 13px; line-height: 1.3;">
                            <%= p.title %>
                            <% if p.deleted %>
                                <span class="deleted-badge">Deleted</span>
                            <% end %>
                        </div>
                        <div class="desc"><%= render_catalog_markdown(p.description) %></div>
                        <% unless p.deleted %>
                            <a href="https://carboncube-ke.com/ads/<%= Ad.slugify(p.title) %>?id=<%= p.id %>" target="_blank" class="view-link">View Online</a>
                        <% end %>
                    </td>
                    <td>
                        <div style="font-weight: 600; font-size: 11px;"><%= p.category_name %></div>
                        <div style="color: var(--secondary); font-size: 10px;"><%= p.subcategory_name %></div>
                    </td>
                    <td class="price">
                        <%= number_with_delimiter(p.price) %>
                    </td>
                </tr>
                <% end %>
            </tbody>
        </table>

        <div class="footer">
            <p>&copy; <%= Time.current.year %> <%= @seller.enterprise_name %>. All rights reserved.</p>
            <p>Confidential Business Document</p>
        </div>
    </div>
</body>
</html>
